{
  "productName": "SPICA TIDE Deck Cargo Planner",
  "version": "1.8.0",
  "identifier": "com.spicatide.app",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SPICA TIDE - Deck Cargo Planner",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "\u00a9 2026 SPICA TIDE. Developed by Pavlo Lagutin. All rights reserved.",
    "category": "Productivity",
    "shortDescription": "Deck cargo planning tool for PSV SPICA TIDE",
    "longDescription": "Professional deck cargo planning application for Platform Supply Vessel SPICA TIDE. Plan, visualise and export cargo placement for North Sea operations.",
    "licenseFile": "EULA.txt",
    "fileAssociations": [
      {
        "ext": ["spica"],
        "mimeType": "application/x-spica-tide",
        "description": "SPICA TIDE Project"
      },
      {
        "ext": ["json"],
        "mimeType": "application/json",
        "description": "SPICA TIDE Project (JSON)"
      }
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"],
        "startMenuFolder": "SPICA TIDE"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/pchekla/spica-deck-cargo-planner/releases/latest/download/latest.json"],
      "pubkey": "REPLACE_WITH_YOUR_PUBLIC_KEY"
    }
  }
}
