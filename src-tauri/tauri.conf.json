{
  "productName": "SPICA TIDE Deck Cargo Plan",
  "version": "1.0.0",
  "identifier": "com.spicatide.app",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SPICA TIDE \u2014 Deck Cargo Plan",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "\u00A9 2026 SPICA TIDE Project. All rights reserved.",
    "category": "Productivity",
    "shortDescription": "Deck cargo planning tool for PSV FAR SPICA",
    "longDescription": "Professional deck cargo planning application for Platform Supply Vessel FAR SPICA. Plan, visualise and export cargo placement for North Sea operations.",
    "licenseFile": "EULA.txt",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"],
        "startMenuFolder": "SPICA TIDE"
      }
    }
  }
}
