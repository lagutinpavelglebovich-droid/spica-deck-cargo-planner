{
  "identifier": "default",
  "description": "Default capabilities for SPICA TIDE desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
